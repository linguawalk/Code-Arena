{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code Arena Question Schema",
  "description": "모든 언어·카테고리에 공통 적용되는 문제 스키마. type에 따라 필요한 필드가 달라짐.",
  "type": "object",
  "required": ["language", "category", "level", "unit", "unit_title", "questions"],
  "properties": {
    "language": {
      "type": "string",
      "description": "언어 코드 (예: c, visual_basic, python, basic_early)"
    },
    "category": {
      "type": "string",
      "enum": ["system_low_level", "oop_enterprise", "scripting", "legacy_historical"]
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "unit": {
      "type": "integer",
      "minimum": 1
    },
    "unit_title": {
      "type": "string",
      "description": "유닛 제목 (한국어)"
    },
    "questions": {
      "type": "array",
      "items": { "$ref": "#/definitions/question" }
    }
  },
  "definitions": {
    "question": {
      "type": "object",
      "required": ["id", "type", "prompt_ko", "explanation_en", "explanation_ko", "concept_tags"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z_]+_l[0-9]+_u[0-9]{2}_q[0-9]{3}$",
          "description": "예: c_l1_u01_q001"
        },
        "type": {
          "type": "string",
          "enum": ["predict_output", "fill_blank", "error_finding", "concept_matching"]
        },
        "code": {
          "type": ["string", "null"],
          "description": "predict_output, fill_blank, error_finding에서 사용. concept_matching은 null."
        },
        "prompt_en": {
          "type": "string",
          "description": "문제 지시문 (영어, 선택)"
        },
        "prompt_ko": {
          "type": "string",
          "description": "문제 지시문 (한국어, 필수)"
        },
        "options": {
          "type": ["array", "null"],
          "description": "predict_output, fill_blank, error_finding용 4지선다 보기. concept_matching은 pairs 필드 사용.",
          "items": { "type": "string" },
          "minItems": 4,
          "maxItems": 4
        },
        "answer": {
          "type": ["integer", "null"],
          "description": "options 배열의 정답 인덱스 (0-based). concept_matching은 null."
        },
        "pairs": {
          "type": ["array", "null"],
          "description": "concept_matching 전용: 좌우 매칭 쌍 목록",
          "items": {
            "type": "object",
            "properties": {
              "term": { "type": "string" },
              "definition": { "type": "string" }
            }
          }
        },
        "explanation_en": { "type": "string" },
        "explanation_ko": { "type": "string" },
        "concept_tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "예: ['variable', 'integer_type'] - 언어 간 개념 비교/검색에 사용"
        },
        "difficulty": {
          "type": "string",
          "enum": ["intro", "practice", "challenge"],
          "default": "practice"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "concept_matching" } } },
          "then": { "required": ["pairs"] },
          "else": { "required": ["code", "options", "answer"] }
        }
      ]
    }
  }
}
